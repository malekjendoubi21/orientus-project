# =============================================================
# Orientus — Root Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control!
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=orientus_db
POSTGRES_USER=orientus_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_STRING_HERE
JWT_EXPIRATION=86400000

# ── Email SMTP ────────────────────────────────────────────
MAIL_USERNAME=contact@orient-us.com
MAIL_PASSWORD=CHANGE_ME_SMTP_APP_PASSWORD

# ── Groq AI API ───────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=CHANGE_ME_YOUR_GROQ_API_KEY

# ── Frontend URLs ─────────────────────────────────────────
VITE_API_URL=http://localhost:8084/api
VITE_WS_URL=http://localhost:8084/ws
FRONTEND_URL=http://localhost:5173

# ── Google Maps ───────────────────────────────────────────
# Get your key at: https://console.cloud.google.com
VITE_GOOGLE_MAPS_API_KEY=CHANGE_ME_YOUR_GOOGLE_MAPS_API_KEY
