# =============================================================
# Orientus Backend — application.properties (EXAMPLE / TEMPLATE)
# Copy this file to application.properties and fill in values
# NEVER commit the real application.properties to git!
# =============================================================

# Application
spring.application.name=orientus

# ── Database PostgreSQL ────────────────────────────────────
# In Docker: use the container name "postgres" as host
# Locally: use "localhost"
spring.datasource.url=jdbc:postgresql://localhost:5432/orientus_db
spring.datasource.username=orientus_user
spring.datasource.password=CHANGE_ME

# ── JPA / Hibernate ────────────────────────────────────────
spring.datasource.driver-class-name=org.postgresql.Driver
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
# Set to false in production
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=false

# ── Flyway (disabled — Hibernate manages schema) ───────────
spring.flyway.enabled=false

# ── Server ─────────────────────────────────────────────────
server.port=8084

# ── JWT ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
jwt.secret=CHANGE_ME_GENERATE_A_RANDOM_64_CHAR_KEY_HERE
jwt.expiration=86400000

# ── File Upload ────────────────────────────────────────────
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# ── Logging (use WARN or ERROR in production) ──────────────
logging.level.root=INFO
logging.level.com.example.orientus=DEBUG
logging.level.org.springframework.security=INFO
logging.level.org.springframework.web=INFO

# ── Chatbot (Groq LLM) ─────────────────────────────────────
# Get your key at: https://console.groq.com/keys
groq.api.key=CHANGE_ME_YOUR_GROQ_API_KEY
groq.api.url=https://api.groq.com/openai/v1/chat/completions
groq.model=llama-3.3-70b-versatile
groq.temperature=0.3
groq.max-tokens=2000

# ── Excel Import (partner universities) ────────────────────
excel.import.path=classpath:data/partner-universities.xlsx
excel.import.enabled=true

# ── Email SMTP ─────────────────────────────────────────────
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=CHANGE_ME_EMAIL@domain.com
spring.mail.password=CHANGE_ME_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true

# ── Connection Pool (HikariCP) ─────────────────────────────
spring.datasource.hikari.minimum-idle=1
spring.datasource.hikari.maximum-pool-size=5
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.connection-timeout=20000
spring.datasource.hikari.keepalive-time=60000

# ── Performance ────────────────────────────────────────────
spring.jmx.enabled=false

# ── ML Service URL ─────────────────────────────────────────
# In Docker: http://ml:5000
# Locally: http://localhost:5000
ml.api.url=http://localhost:5000

# ── Frontend URL (used in email links) ─────────────────────
app.frontend.url=http://localhost:5173

# ── API Rate Limit (per minute) ─────────────────────────────
# Protects chatbot/Groq and recommendation endpoints.
app.rate-limit.chatbot-per-minute=30
app.rate-limit.recommendations-per-minute=20
